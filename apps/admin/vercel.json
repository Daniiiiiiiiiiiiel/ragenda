{
  "version": 2,
  "buildCommand": "cd ../.. && npm install && npm run build:db && npm run build:admin",
  "outputDirectory": "dist",
  "installCommand": "echo 'skip — handled by buildCommand'",
  "framework": "vite",
  "functions": {
    "api/**/*.ts": {
      "memory": 512,
      "maxDuration": 30
    }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
