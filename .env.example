# ========================
# Environment Variables
# ========================
# Copy to .env and fill in values
# NEVER commit .env — it is in .gitignore

# ─── Supabase / PostgreSQL ───────────────────────────────────────────────────
# Connection string WITH connection pooling (for Prisma at runtime)
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct connection WITHOUT pooling (for Prisma migrations only)
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"

# ─── JWT / Auth ──────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET="replace-with-a-secure-random-256bit-secret"
REFRESH_TOKEN_SECRET="replace-with-another-secure-random-256bit-secret"

# ─── Upstash Redis (rate limiting & token blacklist) ─────────────────────────
# Create a free Redis at https://console.upstash.com
UPSTASH_REDIS_REST_URL="https://[your-id].upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-token"

# ─── Resend (transactional email) ────────────────────────────────────────────
# Get your key at https://resend.com/api-keys
RESEND_API_KEY="re_your_resend_api_key"
EMAIL_FROM="RaGenda <no-reply@yourdomain.com>"

# ─── CORS ────────────────────────────────────────────────────────────────────
# Development:
ALLOWED_ORIGINS="http://localhost:5173,http://localhost:5174"
# Production (update after first Vercel deploy):
# ALLOWED_ORIGINS="https://ragenda-web.vercel.app,https://ragenda-admin.vercel.app"

# ─── App URLs ────────────────────────────────────────────────────────────────
# For apps/web — API is same-origin in production (/api), so just /api
VITE_API_URL="/api"

# For apps/admin — same
# VITE_API_URL="/api"

# Optional: cross-link between apps
# VITE_WEB_URL="https://ragenda-web.vercel.app"
# VITE_ADMIN_URL="https://ragenda-admin.vercel.app"

# ─── Runtime ─────────────────────────────────────────────────────────────────
NODE_ENV="production"
