# ========================
# Environment Variables
# ========================
# Copy to .env and fill in values

# ─── Supabase / PostgreSQL ───────────────────────────────────────────────────
# Connection string with connection pooling (for app runtime)
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"
# Direct connection (for Prisma migrations)
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"

# ─── JWT / Auth ──────────────────────────────────────────────────────────────
JWT_SECRET="replace-with-a-secure-random-256bit-secret"
REFRESH_TOKEN_SECRET="replace-with-another-secure-random-256bit-secret"

# ─── Upstash Redis (rate limiting & token blacklist) ─────────────────────────
UPSTASH_REDIS_REST_URL="https://[your-id].upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-token"

# ─── Resend (transactional email) ────────────────────────────────────────────
RESEND_API_KEY="re_your_resend_api_key"
EMAIL_FROM="RaGenda <no-reply@ragenda.app>"

# ─── CORS ────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS="http://localhost:5173,http://localhost:5174"
# In production: "https://ragenda.app,https://admin.ragenda.app"

# ─── App URLs ────────────────────────────────────────────────────────────────
# apps/web .env
VITE_API_URL="http://localhost:3000/api"
VITE_ADMIN_URL="http://localhost:5174"

# apps/admin .env
# VITE_API_URL="http://localhost:3001/api"
# VITE_WEB_URL="http://localhost:5173"

# ─── Misc ────────────────────────────────────────────────────────────────────
NODE_ENV="development"
