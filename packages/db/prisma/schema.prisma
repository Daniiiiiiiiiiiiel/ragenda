generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String        @id @default(cuid())
  email         String        @unique
  passwordHash  String
  name          String
  phone         String?
  role          Role          @default(CLIENT)
  isActive      Boolean       @default(true)
  emailVerified Boolean       @default(false)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  appointments  Appointment[]
  sessions      Session[]

  @@index([email])
  @@index([role])
  @@index([createdAt])
}

model Service {
  id           String        @id @default(cuid())
  name         String
  duration     Int
  description  String?
  price        Float?
  isActive     Boolean       @default(true)
  color        String        @default("#6366f1")
  appointments Appointment[]

  @@index([isActive])
}

model Appointment {
  id         String            @id @default(cuid())
  userId     String
  serviceId  String
  date       DateTime          @db.Date
  timeSlot   String
  status     AppointmentStatus @default(PENDING)
  notes      String?
  adminNotes String?
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
  service    Service           @relation(fields: [serviceId], references: [id])
  user       User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([date])
  @@index([status])
  @@index([serviceId])
  @@index([createdAt])
}

model AvailableSlot {
  id              String   @id @default(cuid())
  date            DateTime @db.Date
  time            String
  maxCapacity     Int      @default(1)
  currentBookings Int      @default(0)
  isBlocked       Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([date, time])
  @@index([date])
  @@index([isBlocked])
}

/// Stores the global schedule configuration (singleton row, id = "default")
model ScheduleConfig {
  id              String   @id @default("default")
  /// JSON array of day numbers: 0=Sun,1=Mon,...,6=Sat. e.g. [1,2,3,4,5]
  workDays        Json     @default("[1,2,3,4,5]")
  /// Start time "HH:MM" e.g. "09:00"
  startTime       String   @default("09:00")
  /// End time "HH:MM" e.g. "18:00"
  endTime         String   @default("18:00")
  /// Slot interval in minutes (15, 20, 30, 45, 60)
  intervalMinutes Int      @default(30)
  /// Max simultaneous bookings per slot
  maxCapacity     Int      @default(1)
  /// How many days ahead clients can book (0 = unlimited)
  bookingWindowDays Int    @default(60)
  /// Break start "HH:MM" optional (e.g. "13:00")
  breakStart      String?
  /// Break end "HH:MM" optional (e.g. "14:00")
  breakEnd        String?
  updatedAt       DateTime @updatedAt
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  userAgent String?
  ipAddress String?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@index([expiresAt])
}

model EmailVerification {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([token])
  @@index([userId])
}

enum Role {
  CLIENT
  ADMIN
}

enum AppointmentStatus {
  PENDING
  ACCEPTED
  REJECTED
  CANCELLED
}
