// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-1.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  CLIENT
  ADMIN
}

enum AppointmentStatus {
  PENDING
  ACCEPTED
  REJECTED
  CANCELLED
}

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  passwordHash  String
  name          String
  phone         String?
  role          Role     @default(CLIENT)
  isActive      Boolean  @default(true)
  emailVerified Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  appointments Appointment[]
  sessions     Session[]

  @@index([email])
  @@index([role])
  @@index([createdAt])
}

model Service {
  id          String  @id @default(cuid())
  name        String
  duration    Int // minutes
  description String?
  price       Float?
  isActive    Boolean @default(true)
  color       String  @default("#6366f1") // for calendar display

  appointments Appointment[]

  @@index([isActive])
}

model Appointment {
  id         String            @id @default(cuid())
  userId     String
  serviceId  String
  date       DateTime          @db.Date
  timeSlot   String // "HH:MM" format e.g. "09:00"
  status     AppointmentStatus @default(PENDING)
  notes      String? // client notes
  adminNotes String? // admin notes (reason for rejection, etc.)
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  service Service @relation(fields: [serviceId], references: [id])

  @@index([userId])
  @@index([date])
  @@index([status])
  @@index([serviceId])
  @@index([createdAt])
}

model AvailableSlot {
  id              String   @id @default(cuid())
  date            DateTime @db.Date
  time            String // "HH:MM" format
  maxCapacity     Int      @default(1)
  currentBookings Int      @default(0)
  isBlocked       Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([date, time])
  @@index([date])
  @@index([isBlocked])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique // hashed refresh token
  expiresAt DateTime
  createdAt DateTime @default(now())
  userAgent String?
  ipAddress String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@index([expiresAt])
}

model EmailVerification {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([token])
  @@index([userId])
}

model ScheduleConfig {
  id           String   @id @default(cuid())
  dayOfWeek    Int      // 0=Sun, 1=Mon, 2=Tue, 3=Wed, 4=Thu, 5=Fri, 6=Sat
  isOpen       Boolean  @default(true)
  openTime     String   @default("09:00") // "HH:MM"
  closeTime    String   @default("17:00") // "HH:MM"
  slotDuration Int      @default(60)      // minutes
  updatedAt    DateTime @updatedAt

  @@unique([dayOfWeek])
  @@index([dayOfWeek])
}
