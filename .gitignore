# ─── Dependencies ─────────────────────────────────────────────────────────────
node_modules/
.pnp
.pnp.js

# ─── Build outputs ────────────────────────────────────────────────────────────
dist/
build/
.next/
out/
*.tsbuildinfo

# ─── Environment variables ────────────────────────────────────────────────────
.env
.env.local
.env.*.local

# ─── Logs ─────────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ─── OS ───────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ─── Editors ──────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ─── TypeScript compiled output (keep only .ts sources) ─────────────────────
# API serverless functions — compiled by tsc locally but Vercel compiles them
apps/*/api/**/*.js
apps/*/api/**/*.js.map
apps/*/api/**/*.d.ts
apps/*/api/**/*.d.ts.map
# src compiled output (Vite handles bundling, tsc declarations not needed)
apps/*/src/**/*.js
apps/*/src/**/*.js.map
apps/*/src/**/*.d.ts
apps/*/src/**/*.d.ts.map

# ─── Prisma ───────────────────────────────────────────────────────────────────
packages/db/node_modules/.prisma

# ─── Vercel ───────────────────────────────────────────────────────────────────
.vercel
