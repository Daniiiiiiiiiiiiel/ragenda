# Auto detect text files and perform LF normalization
* text=auto eol=lf

# Explicitly declare text files to normalize
*.ts    text eol=lf
*.tsx   text eol=lf
*.js    text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.css   text eol=lf
*.html  text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.prisma text eol=lf

# Binary files — no LF normalization
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.svg   binary
*.woff  binary
*.woff2 binary
